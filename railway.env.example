# Railway injects PORT automatically for the deployed service.
# Keep this file as the source of truth for Railway-specific runtime variables.

NODE_ENV=production
LOG_LEVEL=info
DATABASE_URL=<railway-postgres-connection-string>
REDIS_URL=<railway-or-upstash-redis-connection-string>
WEBHOOK_SECRET=<strong-webhook-secret>
IDEMPOTENCY_KEY_TTL_SECONDS=86400
IDEMPOTENCY_IN_PROGRESS_WAIT_MS=5000
PAYMENT_RETRY_QUEUE_NAME=payment-retries
PAYMENT_RETRY_WORKER_CONCURRENCY=2
PAYMENT_RETRY_MAX_ATTEMPTS=3
PAYMENT_DLQ_QUEUE_NAME=payment-dead-letter
ENABLE_STARTUP_CONNECTION_CHECKS=true